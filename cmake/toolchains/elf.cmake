set(CMAKE_SYSTEM_NAME Generic)
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)

if(NOT DEFINED HOJICHA_HOST)
  if(DEFINED ENV{HOST})
    set(HOJICHA_HOST "$ENV{HOST}")
  else()
    set(HOJICHA_HOST x86_64-elf)
  endif()
endif()

set(CMAKE_C_COMPILER "${HOJICHA_HOST}-gcc" CACHE FILEPATH "C compiler" FORCE)
set(CMAKE_ASM_COMPILER "${HOJICHA_HOST}-gcc" CACHE FILEPATH "ASM compiler" FORCE)
set(CMAKE_ASM_NASM_OBJECT_FORMAT elf64 CACHE STRING "NASM object format" FORCE)
set(CMAKE_ASM_NASM_COMPILER nasm CACHE FILEPATH "NASM compiler" FORCE)
set(CMAKE_AR "${HOJICHA_HOST}-ar" CACHE FILEPATH "Archiver" FORCE)
set(CMAKE_RANLIB "${HOJICHA_HOST}-ranlib" CACHE FILEPATH "Ranlib" FORCE)

if(DEFINED HOJICHA_SYSROOT)
  set(CMAKE_SYSROOT "${HOJICHA_SYSROOT}" CACHE PATH "Target sysroot" FORCE)
endif()
